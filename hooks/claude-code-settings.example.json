{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "/absolute/path/to/strata/hooks/pre-read.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/absolute/path/to/strata/hooks/post-edit.sh"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "strata": {
      "command": "node",
      "args": ["/absolute/path/to/strata/dist/index.js"],
      "env": {}
    }
  }
}
